// Zed keymap
//
// Docs: https://zed.dev/docs/key-bindings
[
  // Disable defaults we are remapping
  {
    "context": "Workspace",
    "bindings": {
      "cmd-1": null,
      "cmd-2": null,
      "cmd-3": null,
      "cmd-4": null,
      "cmd-t": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      //"shift shift": "file_finder::Toggle"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-p": "editor::ShowCompletions",
      "cmd-o": "file_finder::Toggle",
      "alt alt-down": [
        "editor::AddSelectionBelow",
        {
          "skip_soft_wrap": true
        }
      ],
    }
  },
  {
    "bindings": {
      "cmd-shift-o": "workspace::Open"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-e": "tab_switcher::Toggle",
      "cmd-shift-a": "command_palette::Toggle"
    }
  },
  {
    "context": "Workspace && !ProjectPanel",
    "bindings": {
      "cmd-1": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "cmd-1": "workspace::CloseActiveDock"
    }
  },
  // CMD+2 git panel: open/focus, then close
  {
    "context": "Workspace && !GitPanel",
    "bindings": {
      "cmd-2": "git_panel::ToggleFocus"
    }
  },
  {
    "context": "GitPanel",
    "bindings": {
      "cmd-2": "workspace::CloseActiveDock"
    }
  },
  // CMD+3 agent panel: open/focus, then close
  {
    "context": "Workspace && !AgentPanel && !AcpThread",
    "bindings": {
      "cmd-3": "agent::ToggleFocus"
    }
  },
  {
    "context": "AgentPanel || AcpThread",
    "bindings": {
      "cmd-3": "workspace::CloseActiveDock"
    }
  },
  // CMD+4 terminal panel: open/focus, then close
  {
    "context": "Workspace && !Terminal",
    "bindings": {
      "cmd-4": "terminal_panel::Toggle",
      "cmd-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-4": "terminal_panel::Toggle",
      "cmd-t": null
    }
  }
]
